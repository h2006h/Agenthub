# ===========================================
# AgentHub 生产环境配置
# 部署到宝塔时，将此文件重命名为 .env
# ===========================================

PORT=3000
JWT_SECRET=请替换为随机32位字符串
NODE_ENV=production

# AI API 配置 (当前使用智谱 GLM)
API_KEY=your_api_key_here
API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
API_MODEL=glm-5.1

# ===========================================
# JWT_SECRET 生成命令 (Linux):
#   openssl rand -hex 32
#   或: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================
